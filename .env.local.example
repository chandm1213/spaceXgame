# Copy to .env.local and fill in. Restart `npm run dev` after changes.

# Privy — wallet connect (https://dashboard.privy.io → create app → App ID)
# Without this, the game runs fine but wallet/leaderboard posting is hidden.
NEXT_PUBLIC_PRIVY_APP_ID=

# Upstash Redis — leaderboard + premium entitlement storage
# Create a free DB at https://console.upstash.com (or Vercel → Storage → Upstash)
# and paste the REST URL + token here. On Vercel, add the same as env vars.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Premium ($SPACEX) purchases ---
# These have working defaults baked into lib/payment.ts; override only to change them.

# Price of the premium unlock, in whole $SPACEX tokens. SET THIS to what you want.
NEXT_PUBLIC_PREMIUM_PRICE=100000

# Token mint (CA) and the wallet that receives payments. Defaults already set to
# your live token + receiving wallet — only set these to change them.
# NEXT_PUBLIC_SPACEX_MINT=52eGV9S6kTUroTXJ1xgbHpcYBm7CNSeoy9XNomCApump
# NEXT_PUBLIC_PREMIUM_RECEIVER=94q7mtD4QFDvvkksjKHowzQWUZPgCDs2BFbgwsD9ieAL

# Solana RPC. Public mainnet works but is rate-limited — use a free Helius/QuickNode
# URL for reliable payment verification. SOLANA_RPC_URL is server-side (verification);
# NEXT_PUBLIC_SOLANA_RPC_URL is client-side (building the transfer).
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# --- Play-to-earn tournaments (entry fee in $SPACEX, winner takes the pot) ---
# Entry fee per run, in whole $SPACEX.
NEXT_PUBLIC_TOURNAMENT_FEE=200000
# Dedicated wallet that collects entry fees (the prize escrow). Defaults to the
# live tournament wallet baked into lib/tournament.ts — override to change it.
# NEXT_PUBLIC_TOURNAMENT_ESCROW=FcYXNzAJCsEtH86ehP1QrUaRWqUc9iDomFB8DkX3bta2
# House rake in basis points (1000 = 10%). Server-side. Winner gets pot*(1-rake).
TOURNAMENT_RAKE_BPS=1000
# Tournament length in hours (168 = weekly, 24 = daily).
NEXT_PUBLIC_TOURNAMENT_PERIOD_HOURS=168
# Secret for the manual-payout admin endpoint:
#   GET /api/tournament/admin?key=YOUR_KEY  -> winner + exact amount to send
# Pick a long random string. Without it the admin endpoint is disabled.
TOURNAMENT_ADMIN_KEY=
